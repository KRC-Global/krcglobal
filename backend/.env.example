# GBMS 환경 변수 설정 예시
# 이 파일을 .env로 복사하여 실제 값을 입력하세요

# Flask 환경 설정
FLASK_ENV=production

# 보안 키 (반드시 변경하세요!)
# 생성 방법 (Python):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-minimum-32-characters
JWT_SECRET_KEY=your-jwt-secret-key-here-minimum-32-characters

# 데이터베이스 (선택사항, 기본값 사용 가능)
# DATABASE_URL=sqlite:///backend/database/gbms.db

# ──────────────────────────────────────────────
# 항공권검색 (/api/flights/*) 외부 데이터 프로바이더
# ──────────────────────────────────────────────
# 활성 프로바이더 선택: 'travelpayouts' (기본) | 'amadeus'
FLIGHT_PROVIDER=travelpayouts

# Travelpayouts (Aviasales) Data API
# 발급: https://www.travelpayouts.com/developers/api  (어필리에이트 가입)
TRAVELPAYOUTS_TOKEN=
# (선택) 어필리에이트 마커 — 외부 OTA 링크 트래킹에 사용
TRAVELPAYOUTS_MARKER=

# Amadeus Self-Service (백업용, 2026-07-17 단종 예정)
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# AMADEUS_BASE_URL=https://test.api.amadeus.com
